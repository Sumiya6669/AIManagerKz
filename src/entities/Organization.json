{
  "name": "Organization",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "\u041d\u0430\u0437\u0432\u0430\u043d\u0438\u0435 \u043e\u0440\u0433\u0430\u043d\u0438\u0437\u0430\u0446\u0438\u0438"
    },
    "business_type": {
      "type": "string",
      "enum": [
        "restaurant",
        "hotel",
        "bath_complex",
        "cafe",
        "restobar",
        "other"
      ],
      "description": "\u0422\u0438\u043f \u0431\u0438\u0437\u043d\u0435\u0441\u0430"
    },
    "bin": {
      "type": "string",
      "description": "\u0411\u0418\u041d \u043e\u0440\u0433\u0430\u043d\u0438\u0437\u0430\u0446\u0438\u0438"
    },
    "phone": {
      "type": "string",
      "description": "\u0422\u0435\u043b\u0435\u0444\u043e\u043d"
    },
    "email": {
      "type": "string",
      "description": "Email"
    },
    "logo_url": {
      "type": "string",
      "description": "URL \u043b\u043e\u0433\u043e\u0442\u0438\u043f\u0430"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "inactive",
        "trial",
        "suspended"
      ],
      "default": "trial"
    },
    "subscription_plan": {
      "type": "string",
      "enum": [
        "free",
        "starter",
        "business",
        "enterprise"
      ],
      "default": "free"
    },
    "settings": {
      "type": "object",
      "description": "\u041d\u0430\u0441\u0442\u0440\u043e\u0439\u043a\u0438 \u043e\u0440\u0433\u0430\u043d\u0438\u0437\u0430\u0446\u0438\u0438"
    }
  },
  "required": [
    "name",
    "business_type"
  ]
}