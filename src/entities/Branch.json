{
  "name": "Branch",
  "type": "object",
  "properties": {
    "organization_id": {
      "type": "string",
      "description": "ID \u043e\u0440\u0433\u0430\u043d\u0438\u0437\u0430\u0446\u0438\u0438"
    },
    "name": {
      "type": "string",
      "description": "\u041d\u0430\u0437\u0432\u0430\u043d\u0438\u0435 \u0444\u0438\u043b\u0438\u0430\u043b\u0430"
    },
    "address": {
      "type": "string",
      "description": "\u0410\u0434\u0440\u0435\u0441"
    },
    "phone": {
      "type": "string",
      "description": "\u0422\u0435\u043b\u0435\u0444\u043e\u043d"
    },
    "city": {
      "type": "string",
      "description": "\u0413\u043e\u0440\u043e\u0434"
    },
    "timezone": {
      "type": "string",
      "default": "Asia/Almaty"
    },
    "working_hours": {
      "type": "object",
      "description": "\u0427\u0430\u0441\u044b \u0440\u0430\u0431\u043e\u0442\u044b \u043f\u043e \u0434\u043d\u044f\u043c"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "inactive"
      ],
      "default": "active"
    }
  },
  "required": [
    "organization_id",
    "name"
  ]
}