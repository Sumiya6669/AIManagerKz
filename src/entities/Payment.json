{
  "name": "Payment",
  "type": "object",
  "properties": {
    "organization_id": {
      "type": "string",
      "description": "ID \u043e\u0440\u0433\u0430\u043d\u0438\u0437\u0430\u0446\u0438\u0438"
    },
    "reservation_id": {
      "type": "string",
      "description": "ID \u0431\u0440\u043e\u043d\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u044f"
    },
    "customer_id": {
      "type": "string",
      "description": "ID \u043a\u043b\u0438\u0435\u043d\u0442\u0430"
    },
    "amount": {
      "type": "number",
      "description": "\u0421\u0443\u043c\u043c\u0430"
    },
    "currency": {
      "type": "string",
      "default": "KZT"
    },
    "provider": {
      "type": "string",
      "enum": [
        "kaspi",
        "halyk",
        "freedom_pay",
        "manual"
      ],
      "description": "\u041f\u0440\u043e\u0432\u0430\u0439\u0434\u0435\u0440 \u043e\u043f\u043b\u0430\u0442\u044b"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "paid",
        "failed",
        "refunded"
      ],
      "default": "pending"
    },
    "payment_url": {
      "type": "string"
    },
    "provider_payment_id": {
      "type": "string"
    },
    "paid_at": {
      "type": "string"
    }
  },
  "required": [
    "organization_id",
    "amount"
  ]
}