      "description": "ID \u043e\u0440\u0433\u0430\u043d\u0438\u0437\u0430\u0446\u0438\u0438"
    },
    "integration_type": {
      "type": "string",
      "enum": [
        "iiko",
        "one_c",
        "kaspi",
        "halyk",
        "freedom_pay",
        "whatsapp",
        "telegram",
        "instagram"
      ],
      "description": "\u0422\u0438\u043f \u0438\u043d\u0442\u0435\u0433\u0440\u0430\u0446\u0438\u0438"
    },
    "status": {
      "type": "string",
      "enum": [
        "connected",
        "disconnected",
        "error",
        "pending"
      ],
      "default": "disconnected"
    },
    "settings": {
      "type": "object",
      "description": "\u041d\u0430\u0441\u0442\u0440\u043e\u0439\u043a\u0438 \u0438\u043d\u0442\u0435\u0433\u0440\u0430\u0446\u0438\u0438"
